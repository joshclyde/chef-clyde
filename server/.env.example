# Copy to .env and fill in. `node --env-file` does NOT expand ~ or variables, so
# every path here must be ABSOLUTE.

ANTHROPIC_API_KEY=sk-ant-...

# Which database this clone talks to. Pick ONE:
#
# Production (only the primary clone you actually run for yourself, native run):
# DB_PATH=/Users/joshclyde/chef-clyde-data/production
#
# Test/development (every other clone + the dev container): an isolated, seeded
# directory inside this clone. After setting it, run `npm run db:seed`.
DB_PATH=/ABSOLUTE/PATH/TO/THIS/CLONE/database
